# Supabase (required for save/share, version history, and live collaboration)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database URL (only needed to run migrations locally)
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Recommended in production (Vercel + Google Cloud Run): canonical public URL, no trailing slash.
# Stabilizes OAuth / logout redirects. On GCP, set to your https://*.run.app (or custom domain).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
